# =====================================================================
# SparkScope 환경 변수
# 이 파일을 .env.local로 복사한 뒤 실제 값으로 채우세요.
# =====================================================================

# --- 데이터베이스 ---
# 개발: SQLite (별도 서비스 가입 불필요)
# 프로덕션: Vercel Postgres 권장
# 예시: postgres://user:password@host/db?sslmode=require
DATABASE_URL="file:./prisma/dev.db"

# --- Anthropic Claude API ---
# console.anthropic.com 에서 발급 (analyzer.ts 외 스크립트에서 아직 사용 중)
ANTHROPIC_API_KEY="sk-ant-..."

# --- OpenAI API ---
# platform.openai.com 에서 발급. analyzer.ts의 기사 분류/심층분석/편집자 인사말에 사용
OPENAI_API_KEY="sk-proj-..."

# --- Resend (메일 발송) ---
# resend.com 에서 발급. 무료 티어 월 3,000건
RESEND_API_KEY="re_..."

# 발신 이메일 (도메인 인증된 주소만 사용 가능)
DIGEST_FROM_EMAIL="sparkscope@sparklabs.co.kr"

# 수신 그룹
DIGEST_TO_GROUP="all@sparklabs.co.kr"

# 시범 운영 중 본인에게만 보내려면 이메일 직접 입력
DIGEST_TEST_RECIPIENT="mido.jang@gmail.com"

# --- Vercel Cron 보안 ---
# 임의의 32자 이상 랜덤 문자열. 외부에서 cron URL을 함부로 호출하지 못하게
CRON_SECRET="change-this-to-a-random-32-char-string-please"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# `openssl rand -base64 32` 로 생성
NEXTAUTH_SECRET="change-this-to-a-random-secret"

# --- 도메인 인증 ---
# 이 도메인의 이메일만 대시보드 접근 가능
ALLOWED_EMAIL_DOMAIN="sparklabs.co.kr"

# --- (옵션) 네이버 뉴스 검색 API ---
# developers.naver.com 에서 발급. 비워두면 Google News RSS만 사용
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
